# =====================================================================
# 設定サンプル。コピーして使う:  cp sample.env .env
# 優先度: コマンドライン引数 > OSの環境変数 > .env > コード内の既定値
# =====================================================================

# ---------- サーバ設定 (server/server.py・docker compose) ----------

# サーバ名。クライアントの「サーバー接続モード」で一致が必要
SERVER_NAME=GameServer

# 待受アドレス (直接起動時のみ有効。Docker利用時はコンテナ内で常に0.0.0.0)
SERVER_BIND=0.0.0.0

# 待受・公開ポート (80 = HTTP標準。大学等のFWを通しやすい。
# 443/https で公開する場合はリバースプロキシでTLS終端して転送する)
SERVER_PORT=80

# ---------- Cloudflare Tunnel (docker compose の cloudflared) ----------

# Cloudflare Zero Trust → Networks → Tunnels で作成したトンネルのトークン。
# トンネル設定の公開ホスト名 (Public Hostname) の Service には
# http://game-server:80 (SERVER_PORT と同じ番号) を指定する。
# クライアントはアドレス欄に https://<公開ホスト名> を入力して接続する。
TUNNEL_TOKEN=

# ---------- クライアント設定 (接続設定ダイアログの初期値) ----------

# 接続先アドレス (IP / ドメイン名 / http(s)://のURL)
CLIENT_ADDRESS=127.0.0.1

# 接続先ポート (サーバー接続モードの初期値)
CLIENT_PORT=80

# サーバ名・ルームID・プレイヤー名の初期値
CLIENT_SERVER_NAME=GameServer
CLIENT_ROOM=room1
CLIENT_PLAYER_NAME=Player
